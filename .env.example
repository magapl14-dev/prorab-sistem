# Copy to /opt/prorab-sistem/backend/.env on the server

DATABASE_URL=postgresql+asyncpg://welldom:CHANGE_PASSWORD@localhost/welldom
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

STORAGE_TYPE=local
UPLOAD_DIR=/opt/prorab-sistem/uploads
PUBLIC_URL=https://welldom05.duckdns.org

JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32

APP_ENV=production
CORS_ORIGINS=https://welldom05.duckdns.org

# Google Sheets sync (paste the full JSON of the service account key as one line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com",...}
