[Unit]
Description=WELL DOM FastAPI
After=network.target postgresql.service

[Service]
User=www-data
WorkingDirectory=/opt/prorab-sistem/backend
EnvironmentFile=/opt/prorab-sistem/backend/.env
ExecStart=/opt/prorab-sistem/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
